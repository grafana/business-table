{
  "name": "volkovlabs-table-panel",
  "description": "Simplify data visualization in table format",
  "version": "3.6.3",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "start": "docker compose --profile dev up",
    "stop": "docker compose --profile dev --profile playwright down --remove-orphans --volumes",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --force-recreate --abort-on-container-exit --exit-code-from playwright",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.5.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.30",
    "@swc/helpers": "^0.5.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "^10.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@floating-ui/react": "^0.27.19",
    "@grafana/data": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/scenes": "^7.4.2",
    "@grafana/ui": "12.4.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@react-aria/focus": "^3.22.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "file-saver": "^2.0.5",
    "handlebars": "^4.7.9",
    "js-base64": "^3.7.8",
    "markdown-it": "^14.1.1",
    "patch-package": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.7.4",
    "tslib": "^2.8.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "@jest/reporters@30.3.0": {
      "glob": "^11.1.0"
    },
    "jest-config@30.3.0": {
      "glob": "^11.1.0"
    },
    "jest-runtime@30.3.0": {
      "glob": "^11.1.0"
    },
    "rimraf@5.0.10": {
      "glob": "^11.1.0"
    },
    "test-exclude": {
      "glob": "^7.2.3"
    }
  }
}
